{
  "expo": {
    "name": "Finance Tracker",
    "slug": "finance-tracker-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "financetracker",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.local.financetracker"
    },
    "android": {
      "package": "com.local.financetracker",
      "permissions": [],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": ["./plugins/withNotificationListener"],
    "extra": {
      "syncMode": "local-first"
    }
  }
}
