{
  "name": "finance-tracker-mobile",
  "version": "0.2.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "api": "npm --prefix apps/api run dev",
    "api:seed": "npm --prefix apps/api run seed",
    "api:smoke": "npm --prefix apps/api run smoke",
    "dev:local": "node scripts/local-dev-start.js",
    "dev:stop": "node scripts/local-dev-stop.js",
    "dev:web": "expo start --web",
    "web": "expo start --web",
    "prebuild": "expo prebuild --platform android",
    "test": "npm run test:parsers && node tests/core.test.js && npm run api:smoke",
    "test:parsers": "node tests/parser.test.js",
    "release:android": "node scripts/release-android.js",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "~51.0.39",
    "expo-clipboard": "~6.0.3",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
